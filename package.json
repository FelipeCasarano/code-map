{
  "name": "code-map",
  "version": "0.1.0",
  "description": "Code Map - Context Routing plugin for coding agents (Claude Code, Codex, Antigravity, any MCP host). Fast file/symbol/route resolver, weighted impact graph, and per-session token-savings ledger.",
  "bin": {
    "cm": "src/cli/index.js",
    "code-map": "src/cli/index.js",
    "code-map-mcp": "src/mcp/server.js",
    "cm-mcp": "src/mcp/server.js"
  },
  "main": "src/core/index.js",
  "type": "commonjs",
  "scripts": {
    "sync": "node src/cli/index.js sync",
    "resolve": "node src/cli/index.js resolve",
    "search": "node src/cli/index.js search",
    "neighbors": "node src/cli/index.js neighbors",
    "impact": "node src/cli/index.js impact",
    "stats": "node src/cli/index.js stats",
    "explain": "node src/cli/index.js explain",
    "mcp": "node src/mcp/server.js",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:self": "node scripts/benchmark-self.js",
    "test": "node tests/run.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "codex",
    "antigravity",
    "mcp",
    "mcp-server",
    "agent",
    "plugin",
    "code-map",
    "context-routing",
    "token-savings",
    "impact-graph",
    "retrieval"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FelipeCasarano/code-map.git"
  },
  "homepage": "https://github.com/FelipeCasarano/code-map",
  "files": [
    "src",
    "skills",
    "commands",
    "hooks",
    "configs",
    "scripts",
    "docs",
    ".claude-plugin",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ]
}
